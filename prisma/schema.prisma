datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "go run github.com/steebchen/prisma-client-go"
  output   = "../internal/database/prisma"
}

model Organization {
  id        String   @id @default(cuid())
  name      String   @unique
  ownerId   String   @map("owner_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members     OrganizationMember[]
  invitations Invitation[]
  monitors    Monitor[]

  @@map("organizations")
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String       @unique @map("user_id")
  role           OrgRole      @default(MEMBER)
  createdAt      DateTime     @default(now()) @map("created_at")

  @@unique([organizationId, userId])
  @@map("organization_members")
}

model Invitation {
  id             String           @id @default(cuid())
  organizationId String           @map("organization_id")
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           OrgRole          @default(MEMBER)
  token          String           @unique
  status         InvitationStatus @default(PENDING)
  invitedBy      String           @map("invited_by")
  expiresAt      DateTime         @map("expires_at")
  createdAt      DateTime         @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([token])
  @@map("invitations")
}

// A subscription belongs to a user (the account), not an organization.
// FREE/PRO are single-user plans; ENTERPRISE additionally unlocks creating an
// organization and inviting seats. An org's effective plan is its owner's plan.
model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique @map("user_id")
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?            @map("stripe_customer_id")
  stripeSubscriptionId String?            @map("stripe_subscription_id")
  stripePriceId        String?            @map("stripe_price_id")
  currentPeriodStart   DateTime?          @map("current_period_start")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  @@map("subscriptions")
}

model Monitor {
  id        String        @id @default(cuid())
  userId    String        @map("user_id")
  orgId     String?       @map("org_id")
  org       Organization? @relation(fields: [orgId], references: [id])
  name      String
  type      MonitorType
  target    String
  interval  Int           @default(60)
  timeout   Int           @default(30)
  enabled   Boolean       @default(true)
  // Region ids (models.Regions registry) this monitor is checked from. Each
  // region's scheduler pool picks up monitors listing its region; incident
  // quorum is majority of this list (see maintenance.record_region_check in
  // migration 20260703120000_add_regions).
  regions   String[]      @default(["na-east"])
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  results         MonitorResult[]
  rollups         MonitorResultRollup[]
  alerts          Alert[]
  incidents       Incident[]
  channelSettings MonitorChannelSetting[]
  regionStatus    MonitorRegionStatus[]

  @@index([userId])
  @@index([orgId])
  @@map("monitors")
}

// Hourly pre-aggregation of monitor_results (one row per monitor per hour),
// used to answer 7d/30d stats without scanning raw rows. Populated by
// maintenance.refresh_rollups() on a host timer — see migration
// 20260627130000_add_result_rollups and docs/runbooks/partitioning.md.
model MonitorResultRollup {
  monitorId  String   @map("monitor_id")
  monitor    Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  region     String   @default("na-east")
  bucket     DateTime
  checks     Int
  sumLatency Int      @map("sum_latency")
  minLatency Int      @map("min_latency")
  maxLatency Int      @map("max_latency")

  @@id([monitorId, region, bucket])
  @@map("monitor_result_rollups")
}

// Partitioned by checked_at (Postgres RANGE). The partition key must be part of
// the primary key, so the PK is composite (id, checked_at) — id alone is still
// globally unique (cuid) and is never used as a lone lookup key. The actual
// PARTITION BY / child-partition DDL is raw SQL (Prisma can't author it); see
// migration 20260627120000_partition_timeseries_tables.
model MonitorResult {
  id         String   @default(cuid())
  monitorId  String   @map("monitor_id")
  monitor    Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  status     Status
  latency    Int
  statusCode Int?     @map("status_code")
  message    String?
  region     String   @default("na-east")
  checkedAt  DateTime @default(now()) @map("checked_at")

  @@id([id, checkedAt])
  @@index([monitorId, checkedAt])
  @@map("monitor_results")
}

// Latest check outcome per (monitor, region): the input to majority-quorum
// incident evaluation and the per-region status shown in the UI. Written
// exclusively by maintenance.record_region_check (one row upserted per
// check); rows for regions removed from a monitor are cleaned up on update
// and ignored by quorum either way.
model MonitorRegionStatus {
  monitorId  String   @map("monitor_id")
  monitor    Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  region     String
  status     Status
  latency    Int      @default(0)
  statusCode Int?     @map("status_code")
  message    String?
  checkedAt  DateTime @default(now()) @map("checked_at")

  @@id([monitorId, region])
  @@map("monitor_region_status")
}

model Incident {
  id         String    @id @default(cuid())
  monitorId  String    @map("monitor_id")
  monitor    Monitor   @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  status     Status
  startedAt  DateTime  @default(now()) @map("started_at")
  resolvedAt DateTime? @map("resolved_at")
  statusCode Int?      @map("status_code")
  message    String?
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([monitorId, startedAt])
  @@index([monitorId, resolvedAt])
  @@map("incidents")
}

// RETIRED — per-monitor alerts were folded into NotificationChannel +
// MonitorChannelSetting (see migration 20260702130000_fold_alerts_into_channels).
// No code reads or writes this table; it survives only because alert_history
// audit rows cascade-delete with their alert. Drop both together later.
model Alert {
  id        String       @id @default(cuid())
  monitorId String       @map("monitor_id")
  monitor   Monitor      @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  channel   AlertChannel
  target    String
  enabled   Boolean      @default(true)
  createdAt DateTime     @default(now()) @map("created_at")

  history AlertHistory[]
  outbox  AlertOutbox[]

  @@map("alerts")
}

// A user's global (account-level) alert channels. Every monitor the user (or
// their org, resolved via the org owner) owns inherits these by default;
// MonitorChannelSetting rows override the enabled flag per monitor.
model NotificationChannel {
  id        String       @id @default(cuid())
  userId    String       @map("user_id")
  channel   AlertChannel
  target    String
  enabled   Boolean      @default(true)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  monitorSettings MonitorChannelSetting[]
  history         AlertHistory[]
  outbox          AlertOutbox[]

  @@index([userId])
  @@map("notification_channels")
}

// Per-monitor opt-in/opt-out override of a global channel. Absent row =
// inherit the channel's own enabled flag; deleting a row reverts to inherit.
model MonitorChannelSetting {
  id                    String              @id @default(cuid())
  monitorId             String              @map("monitor_id")
  monitor               Monitor             @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  notificationChannelId String              @map("notification_channel_id")
  notificationChannel   NotificationChannel @relation(fields: [notificationChannelId], references: [id], onDelete: Cascade)
  enabled               Boolean
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  @@unique([monitorId, notificationChannelId])
  @@map("monitor_channel_settings")
}

// Pending alert deliveries (transactional-outbox pattern). The scheduler
// enqueues a row per alert config when an incident transition happens; a
// dispatcher drains due rows with FOR UPDATE SKIP LOCKED (safe with many
// scheduler instances), retries with exponential backoff, and deletes the row
// on success or after max attempts. Monitor fields are denormalized so the
// dispatcher sends exactly what was true at enqueue time, with no joins.
// Exactly one of alertId / notificationChannelId is set (DB CHECK constraint):
// the row's source is either a per-monitor alert or a global channel.
model AlertOutbox {
  id                    String               @id @default(cuid())
  alertId               String?              @map("alert_id")
  alert                 Alert?               @relation(fields: [alertId], references: [id], onDelete: Cascade)
  notificationChannelId String?              @map("notification_channel_id")
  notificationChannel   NotificationChannel? @relation(fields: [notificationChannelId], references: [id], onDelete: Cascade)
  monitorId     String      @map("monitor_id")
  channel       AlertChannel
  target        String
  status        Status
  message       String
  statusCode    Int?        @map("status_code")
  latency       Int         @default(0)
  monitorName   String      @map("monitor_name")
  monitorType   MonitorType @map("monitor_type")
  monitorTarget String      @map("monitor_target")
  attempts      Int         @default(0)
  nextAttemptAt DateTime    @default(now()) @map("next_attempt_at")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([nextAttemptAt])
  @@map("alert_outbox")
}

// Partitioned by sent_at (Postgres RANGE); composite PK (id, sent_at) for the
// same reason as MonitorResult. Write-only audit log — never read by the app.
// Exactly one of alertId / notificationChannelId is set (DB CHECK constraint).
model AlertHistory {
  id                    String               @default(cuid())
  alertId               String?              @map("alert_id")
  alert                 Alert?               @relation(fields: [alertId], references: [id], onDelete: Cascade)
  notificationChannelId String?              @map("notification_channel_id")
  notificationChannel   NotificationChannel? @relation(fields: [notificationChannelId], references: [id], onDelete: Cascade)
  status  Status
  message String
  sentAt  DateTime @default(now()) @map("sent_at")

  @@id([id, sentAt])
  @@index([alertId, sentAt])
  @@map("alert_history")
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum MonitorType {
  HTTP
  PORT
  PING
}

enum AlertChannel {
  EMAIL
  SMS
  DISCORD
  SLACK
  TELEGRAM
}

enum Status {
  UP
  DOWN
  DEGRADED
}
