datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "go run github.com/steebchen/prisma-client-go"
  output   = "../internal/database/prisma"
}

model Organization {
  id        String   @id @default(cuid())
  name      String   @unique
  ownerId   String   @map("owner_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members     OrganizationMember[]
  invitations Invitation[]
  monitors    Monitor[]

  @@map("organizations")
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String       @unique @map("user_id")
  role           OrgRole      @default(MEMBER)
  createdAt      DateTime     @default(now()) @map("created_at")

  @@unique([organizationId, userId])
  @@map("organization_members")
}

model Invitation {
  id             String           @id @default(cuid())
  organizationId String           @map("organization_id")
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           OrgRole          @default(MEMBER)
  token          String           @unique
  status         InvitationStatus @default(PENDING)
  invitedBy      String           @map("invited_by")
  expiresAt      DateTime         @map("expires_at")
  createdAt      DateTime         @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([token])
  @@map("invitations")
}

// A subscription belongs to a user (the account), not an organization.
// FREE/PRO are single-user plans; ENTERPRISE additionally unlocks creating an
// organization and inviting seats. An org's effective plan is its owner's plan.
model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique @map("user_id")
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?            @map("stripe_customer_id")
  stripeSubscriptionId String?            @map("stripe_subscription_id")
  stripePriceId        String?            @map("stripe_price_id")
  currentPeriodStart   DateTime?          @map("current_period_start")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  @@map("subscriptions")
}

model Monitor {
  id        String        @id @default(cuid())
  userId    String        @map("user_id")
  orgId     String?       @map("org_id")
  org       Organization? @relation(fields: [orgId], references: [id])
  name      String
  type      MonitorType
  target    String
  interval  Int           @default(60)
  timeout   Int           @default(30)
  enabled   Boolean       @default(true)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  results   MonitorResult[]
  rollups   MonitorResultRollup[]
  alerts    Alert[]
  incidents Incident[]

  @@index([userId])
  @@index([orgId])
  @@map("monitors")
}

// Hourly pre-aggregation of monitor_results (one row per monitor per hour),
// used to answer 7d/30d stats without scanning raw rows. Populated by
// maintenance.refresh_rollups() on a host timer — see migration
// 20260627130000_add_result_rollups and docs/runbooks/partitioning.md.
model MonitorResultRollup {
  monitorId  String   @map("monitor_id")
  monitor    Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  bucket     DateTime
  checks     Int
  sumLatency Int      @map("sum_latency")
  minLatency Int      @map("min_latency")
  maxLatency Int      @map("max_latency")

  @@id([monitorId, bucket])
  @@map("monitor_result_rollups")
}

// Partitioned by checked_at (Postgres RANGE). The partition key must be part of
// the primary key, so the PK is composite (id, checked_at) — id alone is still
// globally unique (cuid) and is never used as a lone lookup key. The actual
// PARTITION BY / child-partition DDL is raw SQL (Prisma can't author it); see
// migration 20260627120000_partition_timeseries_tables.
model MonitorResult {
  id         String   @default(cuid())
  monitorId  String   @map("monitor_id")
  monitor    Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  status     Status
  latency    Int
  statusCode Int?     @map("status_code")
  message    String?
  checkedAt  DateTime @default(now()) @map("checked_at")

  @@id([id, checkedAt])
  @@index([monitorId, checkedAt])
  @@map("monitor_results")
}

model Incident {
  id         String    @id @default(cuid())
  monitorId  String    @map("monitor_id")
  monitor    Monitor   @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  status     Status
  startedAt  DateTime  @default(now()) @map("started_at")
  resolvedAt DateTime? @map("resolved_at")
  statusCode Int?      @map("status_code")
  message    String?
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([monitorId, startedAt])
  @@index([monitorId, resolvedAt])
  @@map("incidents")
}

model Alert {
  id        String       @id @default(cuid())
  monitorId String       @map("monitor_id")
  monitor   Monitor      @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  channel   AlertChannel
  target    String
  enabled   Boolean      @default(true)
  createdAt DateTime     @default(now()) @map("created_at")

  history AlertHistory[]
  outbox  AlertOutbox[]

  @@map("alerts")
}

// Pending alert deliveries (transactional-outbox pattern). The scheduler
// enqueues a row per alert config when an incident transition happens; a
// dispatcher drains due rows with FOR UPDATE SKIP LOCKED (safe with many
// scheduler instances), retries with exponential backoff, and deletes the row
// on success or after max attempts. Monitor fields are denormalized so the
// dispatcher sends exactly what was true at enqueue time, with no joins.
model AlertOutbox {
  id            String      @id @default(cuid())
  alertId       String      @map("alert_id")
  alert         Alert       @relation(fields: [alertId], references: [id], onDelete: Cascade)
  monitorId     String      @map("monitor_id")
  channel       AlertChannel
  target        String
  status        Status
  message       String
  statusCode    Int?        @map("status_code")
  latency       Int         @default(0)
  monitorName   String      @map("monitor_name")
  monitorType   MonitorType @map("monitor_type")
  monitorTarget String      @map("monitor_target")
  attempts      Int         @default(0)
  nextAttemptAt DateTime    @default(now()) @map("next_attempt_at")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([nextAttemptAt])
  @@map("alert_outbox")
}

// Partitioned by sent_at (Postgres RANGE); composite PK (id, sent_at) for the
// same reason as MonitorResult. Write-only audit log — never read by the app.
model AlertHistory {
  id      String   @default(cuid())
  alertId String   @map("alert_id")
  alert   Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  status  Status
  message String
  sentAt  DateTime @default(now()) @map("sent_at")

  @@id([id, sentAt])
  @@index([alertId, sentAt])
  @@map("alert_history")
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum MonitorType {
  HTTP
  PORT
  PING
}

enum AlertChannel {
  EMAIL
  SMS
  DISCORD
  SLACK
}

enum Status {
  UP
  DOWN
  DEGRADED
}
